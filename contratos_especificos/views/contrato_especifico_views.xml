<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contrato_especifico_form" model="ir.ui.view">
        <field name="name">contrato.especifico.form</field>
        <field name="model">contrato.especifico</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_content" string="Generate Content" type="object" class="oe_highlight" invisible="state == 'firmado'"/>
                    <button name="action_sign" string="Sign Contract" type="object" class="oe_highlight" invisible="state == 'firmado'" confirm="Are you sure you want to sign this contract? This action is irreversible."/>
                    <button name="action_set_to_pending" string="Set to Pending" type="object" groups="base.group_system" invisible="state == 'pendiente'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Contract Ref."/>
                        <h1>
                            <field name="name" placeholder="e.g. CE-001" autocomplete="off"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General Information">
                            <field name="marco_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="contract_type" readonly="1"/>
                            <field name="template_id" string="Contract Type"/>
                            <field name="state" widget="radio" options="{'horizontal': true}" readonly="1"/>
                        </group>
                        <group string="Dates">
                            <field name="date"/>
                            <field name="start_date" required="template_id"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Representation">
                            <field name="our_representative_id" required="template_type_requires_rep"/>
                            <field name="our_rep_decision_number" string="Agreement/Decision" autocomplete="off" required="template_type_requires_rep"/>
                            <field name="our_rep_decision_date" required="template_type_requires_rep"/>
                            <field name="project_leader" autocomplete="off" required="template_type_requires_leader" invisible="not template_type_requires_leader"/>
                            <field name="application_name" autocomplete="off" required="template_type_requires_app" invisible="not template_type_requires_app"/>
                            <field name="template_type_requires_rep" invisible="1"/>
                            <field name="template_type_requires_leader" invisible="1"/>
                            <field name="template_type_requires_app" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Anexo No.1 (Servicios)" name="service_lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal"/>
                                    <field name="date_deadline_invoice"/>
                                    <field name="invoiced" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Contract Content">
                            <div style="max-width: 800px; margin: 0 auto; border: 1px solid #dee2e6; padding: 40px; background: white; min-height: 1000px; overflow-wrap: break-word; font-family: 'Times New Roman', Times, serif;">
                                <field name="content" widget="html" options="{'style-inline': true}"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_contrato_especifico_tree" model="ir.ui.view">
        <field name="name">contrato.especifico.tree</field>
        <field name="model">contrato.especifico</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'pendiente'" decoration-success="state == 'firmado'" multi_edit="1">
                <field name="name" readonly="1"/>
                <field name="marco_id" readonly="1"/>
                <field name="partner_id" readonly="1"/>
                <field name="template_id" string="Contract Type" readonly="1"/>
                <field name="date" readonly="1" optional="hide"/>
                <field name="start_date" optional="show"/>
                <field name="end_date" optional="show"/>
                <field name="state" widget="badge" decoration-info="state == 'pendiente'" decoration-success="state == 'firmado'"/>
            </tree>
        </field>
    </record>

    <record id="view_contrato_especifico_search" model="ir.ui.view">
        <field name="name">contrato.especifico.search</field>
        <field name="model">contrato.especifico</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="marco_id"/>

                <filter string="Pending" name="state_pendiente" domain="[('state', '=', 'pendiente')]"/>
                <filter string="Signed" name="state_firmado" domain="[('state', '=', 'firmado')]"/>
                <separator/>
                <filter string="End Date" name="end_date" date="end_date"/>

                <group expand="0" string="Group By">
                    <filter string="Master Contract" name="group_marco" context="{'group_by': 'marco_id'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Client Type" name="group_type" context="{'group_by': 'contract_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_contrato_especifico" model="ir.actions.act_window">
        <field name="name">Specific Contracts</field>
        <field name="res_model">contrato.especifico</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_contrato_especifico_search"/>
    </record>

    <menuitem id="menu_contrato_especifico"
              name="Specific Contracts"
              parent="contratos.menu_contrato_root"
              action="action_contrato_especifico"
              sequence="20"/>
</odoo>
