<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contrato_especifico_form" model="ir.ui.view">
        <field name="name">contrato.especifico.form</field>
        <field name="model">contrato.especifico</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_content" string="Generate Content" type="object" class="oe_highlight" invisible="state in ('firmado', 'entregado')"/>
                    <button name="action_sign" string="Entregar" type="object" class="oe_highlight" invisible="state in ('firmado', 'entregado')" confirm="¿Está seguro de que desea entregar este contrato?"/>
                    <button name="action_draft_from_entregado" string="Retroceder a Borrador" type="object" invisible="state != 'entregado'"/>
                    <button name="action_entregar" string="Firmar" type="object" class="oe_highlight" invisible="state != 'entregado'" confirm="¿Está seguro de que desea firmar este contrato? Esta acción no se puede deshacer."/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('borrador', 'entregado', 'firmado')"/>
                    <button name="action_draft" string="Set to Draft" type="object" invisible="state not in ('cancelado',)"/>
                    <field name="state" widget="statusbar" statusbar_visible="borrador,entregado,firmado,cancelado"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Número del contrato"/>
                        <h1>
                            <field name="name" placeholder="e.g. CE-001" autocomplete="off"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Información General">
                            <field name="marco_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="template_id" string="Tipo de Contrato"/>
                        </group>
                        <group name="dates" string="Fechas">
                            <field name="date" string="Fecha del Contrato"/>
                            <field name="start_date" required="template_id" string="Fecha de Inicio"/>
                            <field name="end_date" string="Fecha Final"/>
                        </group>
                    </group>
                    <group>
                        <group string="Representación">
                            <field name="our_representative_id" required="template_type_requires_rep" string="Nuestro Representante"/>
                            <field name="our_rep_decision_number" string="Acuerdo/Resolución" autocomplete="off" required="template_type_requires_rep"/>
                            <field name="our_rep_decision_date" string="Fecha de Resolución" required="template_type_requires_rep"/>
                            <field name="our_project_leader_id"/>
                            <field name="project_leader_id" options="{'no_create': True}" string="Líder del Proyecto del Cliente"/>
                            <field name="application_name" autocomplete="off" string="Nombre de la Aplicación"/>
                            <field name="template_type_requires_rep" invisible="1"/>
                            <field name="template_type_requires_leader" invisible="1"/>
                            <field name="template_type_requires_app" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Datos de Facturación">
                            <field name="forma_pago_id" options="{'no_create': True}"/>
                            <field name="realizada_por_id" options="{'no_create': True}"/>
                            <field name="transportado_por_id" options="{'no_create': True}"/>
                            <field name="recibido_por_id" options="{'no_create': True}"/>
                            <field name="entregada_por_id" options="{'no_create': True}"/>
                            <field name="contabilizada_por_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas de servicios" name="service_lines">
                            <field name="line_ids" readonly="state == 'firmado'">
                                <tree editable="bottom">
                                    <field name="product_id" string="Producto/Servicio"/>
                                    <field name="name" string="Descripción"/>
                                    <field name="start_date" optional="show"/>
                                    <field name="end_date" optional="show"/>
                                    <field name="quantity" string="Cant."/>
                                    <field name="uom_id" string="UdM"/>
                                    <field name="price_unit" string="Precio Unitario"/>
                                    <field name="price_subtotal" string="Subtotal"/>
                                    <field name="date_deadline_invoice" string="Límite Facturación"/>
                                    <field name="invoiced" optional="hide" string="Facturado"/>
                                    <button name="action_facturar" type="object" string="Facturar" class="btn-primary" invisible="invoiced"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Líneas de Servicio por UEB" name="ueb_sections">
                            <div class="mb-2">
                                <button name="action_add_ueb_section" type="object"
                                        string="+ Agregar UEB" class="btn btn-primary"
                                        invisible="state == 'firmado'"/>
                            </div>
                            <field name="ueb_section_ids" create="0" delete="0" readonly="state == 'firmado'">
                                <tree create="0" delete="0" decoration-muted="line_count == 0">
                                    <field name="ueb_id" string="UEB"/>
                                    <field name="line_count" string="Nº Líneas"/>
                                    <field name="total_amount" string="Total" widget="monetary"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <div class="oe_title">
                                            <h2>
                                                <field name="ueb_id" readonly="1"/>
                                            </h2>
                                        </div>
                                        <field name="contract_state" invisible="1"/>
                                        <field name="line_ids" readonly="contract_state == 'firmado'">
                                            <tree editable="bottom">
                                                <field name="product_id" string="Producto/Servicio"/>
                                                <field name="name" string="Descripción"/>
                                                <field name="start_date" optional="show"/>
                                                <field name="end_date" optional="show"/>
                                                <field name="quantity" string="Cant."/>
                                                <field name="uom_id" string="UdM"/>
                                                <field name="price_unit" string="Precio Unitario"/>
                                                <field name="price_subtotal" string="Subtotal"/>
                                                <field name="date_deadline_invoice" string="Límite Facturación"/>
                                                <field name="invoiced" optional="hide" string="Facturado"/>
                                                <button name="action_facturar" type="object" string="Facturar"
                                                        class="btn-primary" invisible="invoiced"/>
                                                <button name="action_uninvoice" type="object" string="Desmarcar"
                                                        class="btn-warning" invisible="not invoiced"/>
                                            </tree>
                                        </field>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Contract Content">
                            <div style="max-width: 800px; margin: 0 auto; border: 1px solid #dee2e6; padding: 40px; background: white; min-height: 1000px; overflow-wrap: break-word; font-family: 'Times New Roman', Times, serif;">
                                <field name="content" widget="html" options="{'style-inline': true}"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_contrato_especifico_tree" model="ir.ui.view">
        <field name="name">contrato.especifico.tree</field>
        <field name="model">contrato.especifico</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'borrador'" decoration-success="state == 'firmado'" decoration-warning="state == 'entregado'" decoration-muted="state == 'cancelado'" multi_edit="1">
                <field name="name" readonly="1"/>
                <field name="marco_id" readonly="1"/>
                <field name="partner_id" readonly="1"/>
                <field name="template_id" string="Contract Type" readonly="1"/>
                <field name="date" readonly="1" optional="hide"/>
                <field name="start_date" optional="show"/>
                <field name="end_date" optional="show"/>
                <field name="state" widget="badge" decoration-info="state == 'borrador'" decoration-success="state == 'firmado'" decoration-warning="state == 'entregado'" decoration-muted="state == 'cancelado'"/>
            </tree>
        </field>
    </record>

    <record id="view_contrato_especifico_search" model="ir.ui.view">
        <field name="name">contrato.especifico.search</field>
        <field name="model">contrato.especifico</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="marco_id"/>

                <filter string="Draft" name="state_borrador" domain="[('state', '=', 'borrador')]"/>
                <filter string="Signed" name="state_firmado" domain="[('state', '=', 'firmado')]"/>
                <filter string="Entregado" name="state_entregado" domain="[('state', '=', 'entregado')]"/>
                <filter string="Cancelled" name="state_cancelado" domain="[('state', '=', 'cancelado')]"/>
                <separator/>
                <filter string="End Date" name="end_date" date="end_date"/>

                <group expand="0" string="Group By">
                    <filter string="Master Contract" name="group_marco" context="{'group_by': 'marco_id'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Contract Type" name="group_type" context="{'group_by': 'contract_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_contrato_especifico" model="ir.actions.act_window">
        <field name="name">Specific Contracts</field>
        <field name="res_model">contrato.especifico</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_contrato_especifico_search"/>
    </record>

    <menuitem id="menu_contrato_especifico"
              name="Specific Contracts"
              parent="contratos.menu_contrato_root"
              action="action_contrato_especifico"
              sequence="20"/>
</odoo>
