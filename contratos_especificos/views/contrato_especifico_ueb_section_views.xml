<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard: Agregar UEB a contrato específico -->
    <record id="view_add_ueb_section_wizard_form" model="ir.ui.view">
        <field name="name">contrato.especifico.add.ueb.wizard.form</field>
        <field name="model">contrato.especifico.add.ueb.wizard</field>
        <field name="arch" type="xml">
            <form string="Agregar tabla de líneas de servicio por UEB">
                <sheet>
                    <group>
                        <field name="contrato_id" invisible="1"/>
                        <field name="available_ueb_ids" invisible="1"/>
                        <field name="ueb_id" options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Añadir" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Form view for UEB section (opened as popup from One2many) -->
    <record id="view_contrato_especifico_ueb_section_form" model="ir.ui.view">
        <field name="name">contrato.especifico.ueb.section.form</field>
        <field name="model">contrato.especifico.ueb.section</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h2>
                            <field name="ueb_id" readonly="1"/>
                        </h2>
                    </div>
                    <field name="contract_state" invisible="1"/>
                    <field name="line_ids" readonly="contract_state == 'firmado'">
                        <tree editable="bottom">
                            <field name="product_id" string="Producto/Servicio"/>
                            <field name="name" string="Descripción"/>
                            <field name="start_date" optional="show"/>
                            <field name="end_date" optional="show"/>
                            <field name="quantity" string="Cant."/>
                            <field name="uom_id" string="UdM"/>
                            <field name="price_unit" string="Precio Unitario"/>
                            <field name="price_subtotal" string="Subtotal"/>
                            <field name="date_deadline_invoice" string="Límite Facturación"/>
                            <field name="invoiced" optional="hide" string="Facturado"/>
                            <button name="action_facturar" type="object" string="Facturar"
                                    class="btn-primary" invisible="invoiced"/>
                            <button name="action_uninvoice" type="object" string="Desmarcar"
                                    class="btn-warning" invisible="not invoiced"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree view for UEB sections (shown inline in contract form) -->
    <record id="view_contrato_especifico_ueb_section_tree" model="ir.ui.view">
        <field name="name">contrato.especifico.ueb.section.tree</field>
        <field name="model">contrato.especifico.ueb.section</field>
        <field name="arch" type="xml">
            <tree decoration-muted="line_count == 0">
                <field name="ueb_id" string="UEB"/>
                <field name="line_count" string="Nº Líneas"/>
                <field name="total_amount" string="Total" widget="monetary"/>
            </tree>
        </field>
    </record>

</odoo>
