<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contrato_especifico_import_wizard_form" model="ir.ui.view">
        <field name="name">contrato.especifico.import.wizard.form</field>
        <field name="model">contrato.especifico.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import TXT Template">
                <group>
                    <field name="template_id" invisible="1"/>
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_contrato_especifico_import_wizard" model="ir.actions.act_window">
        <field name="name">Import TXT</field>
        <field name="res_model">contrato.especifico.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
