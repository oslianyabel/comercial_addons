<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_contrato_marco" model="ir.sequence">
            <field name="name">Contrato Marco</field>
            <field name="code">contrato.marco.sequence</field>
            <field name="prefix">CM </field>
            <field name="suffix">-%(y)s</field>
            <field name="padding">2</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
            <field name="use_date_range">True</field>
        </record>
        <record id="seq_contrato_suplemento" model="ir.sequence">
            <field name="name">Suplemento de Contrato Marco</field>
            <field name="code">contrato.suplemento.sequence</field>
            <field name="prefix">SUP </field>
            <field name="suffix">-%(y)s</field>
            <field name="padding">2</field>
            <field name="number_increment">1</field>
            <field name="implementation">standard</field>
            <field name="use_date_range">True</field>
        </record>
    </data>
</odoo>