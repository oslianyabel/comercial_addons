<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_contrato_marco_form" model="ir.ui.view">
        <field name="name">contrato.marco.form</field>
        <field name="model">contrato.marco</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_content" string="Generate Content" type="object" class="oe_highlight" invisible="state in ('firmado', 'entregado')"/>
                    <button name="action_sign" string="Entregar" type="object" class="oe_highlight" invisible="state in ('firmado', 'entregado')" confirm="¿Está seguro de que desea entregar este contrato?"/>
                    <button name="action_draft_from_entregado" string="Retroceder a Borrador" type="object" invisible="state != 'entregado'"/>
                    <button name="action_entregar" string="Firmar" type="object" class="oe_highlight" invisible="state != 'entregado'" confirm="¿Está seguro de que desea firmar este contrato? Esta acción no se puede deshacer."/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('borrador', 'entregado', 'firmado')"/>
                    <button name="action_draft" string="Set to Draft" type="object" invisible="state != 'cancelado'"/>
                    <field name="state" widget="statusbar" statusbar_visible="borrador,entregado,firmado,cancelado"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Contract Ref."/>
                        <h1>
                            <field name="name" placeholder="e.g. 001/2026" autocomplete="off"/>
                        </h1>
                        <label for="contract_name" string="Contract Title"/>
                        <h2>
                            <field name="contract_name" placeholder="Describe the contract..." autocomplete="off"/>
                        </h2>
                    </div>
                    <group>
                        <group string="General Information">
                            <field name="company_id"/>
                            <field name="partner_id"/>
                            <field name="contract_type"/>
                            <field name="file_number" string="File Ref." autocomplete="off"/>
                            <field name="hco"/>
                        </group>
                        <group name="dates_and_signatures" string="Dates and Signatures">
                            <field name="date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="validity_date"/>
                            <field name="signing_date" invisible="state == 'borrador'"/>
                        </group>
                    </group>
                    <group>
                        <group string="Representation">
                            <field name="representative_id"/>
                            <field name="our_representative_id"/>
                            <field name="authorized_contact_ids" widget="many2many_tags"/>
                            <field name="our_rep_decision_number" string="Agreement/Decision" autocomplete="off"/>
                            <field name="our_rep_decision_date"/>
                        </group>
                        <group string="Traceability">
                            <field name="created_by_id" widget="many2one_avatar_user"/>
                            <field name="signed_by_id" invisible="state == 'borrador'"/>
                            <field name="creation_date_auto"/>
                            <field name="modification_date_auto"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contract Content">
                            <div style="max-width: 800px; margin: 0 auto; border: 1px solid #dee2e6; padding: 40px; background: white; min-height: 1000px; overflow-wrap: break-word; font-family: 'Times New Roman', Times, serif;">
                                <field name="content" widget="html" options="{'style-inline': true}"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_contrato_marco_tree" model="ir.ui.view">
        <field name="name">contrato.marco.tree</field>
        <field name="model">contrato.marco</field>
        <field name="arch" type="xml">
            <tree decoration-info="state == 'borrador'" decoration-success="state == 'firmado'" decoration-warning="state == 'entregado'" decoration-muted="state == 'cancelado'" multi_edit="1">
                <field name="name" readonly="1"/>
                <field name="company_id" readonly="1" optional="hide"/>
                <field name="contract_type" readonly="1"/>
                <field name="contract_name"/>
                <field name="partner_id" readonly="1"/>
                <field name="our_representative_id"/>
                <field name="created_by_id" widget="many2one_avatar_user" optional="show"/>
                <field name="signed_by_id" optional="show"/>
                <field name="date" readonly="1" optional="hide"/>
                <field name="signing_date" optional="show"/>
                <field name="end_date" readonly="1"/>
                <field name="state" widget="badge" decoration-info="state == 'borrador'" decoration-success="state == 'firmado'" decoration-warning="state == 'entregado'" decoration-muted="state == 'cancelado'"/>
            </tree>
        </field>
    </record>

    <record id="view_contrato_marco_search" model="ir.ui.view">
        <field name="name">contrato.marco.search</field>
        <field name="model">contrato.marco</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="contract_name"/>
                <field name="partner_id"/>
                <field name="file_number"/>
                
                <filter string="HCO" name="hco" domain="[('hco', '=', True)]"/>
                <separator/>
                <filter string="Draft" name="state_borrador" domain="[('state', '=', 'borrador')]"/>
                <filter string="Signed" name="state_firmado" domain="[('state', '=', 'firmado')]"/>
                <filter string="Entregado" name="state_entregado" domain="[('state', '=', 'entregado')]"/>
                <filter string="Cancelled" name="state_cancelado" domain="[('state', '=', 'cancelado')]"/>
                <separator/>
                <filter string="End Date" name="end_date" date="end_date"/>
                
                <group expand="0" string="Group By">
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Contract Type" name="group_type" context="{'group_by': 'contract_type'}"/>
                    <filter string="HCO" name="group_hco" context="{'group_by': 'hco'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_contrato_marco" model="ir.actions.act_window">
        <field name="name">Master Contracts</field>
        <field name="res_model">contrato.marco</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_contrato_marco_search"/>
    </record>

    <menuitem id="menu_contrato_root" name="Contracts" sequence="10" web_icon="contratos,static/description/icon.png"/>
    <menuitem id="menu_contrato_marco" name="Master Contracts" parent="menu_contrato_root" action="action_contrato_marco" sequence="10"/>
</odoo>
