<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_signature_selection_wizard_form" model="ir.ui.view">
        <field name="name">signature.selection.wizard.form</field>
        <field name="model">signature.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Facturar Servicio">
                <group col="4">
                    <field name="line_id" readonly="1" invisible="1"/>
                    <field name="contrato_id" readonly="1"/>
                    <field name="payment_form_id" options="{'no_create': True}"/>
                </group>
                <group>
                    <group string="Operaciones">
                        <label for="realizada_por_id" string="Realizada por"/>
                        <div class="o_row">
                            <field name="realizada_por_id" options="{'no_create': True}"/>
                            <label for="realizada_fecha" string="Fecha"/>
                            <field name="realizada_fecha"/>
                        </div>
                        
                        <label for="transportado_por_id" string="Transportado por"/>
                        <div class="o_row">
                            <field name="transportado_por_id" options="{'no_create': True}"/>
                            <label for="transportado_fecha" string="Fecha"/>
                            <field name="transportado_fecha"/>
                        </div>

                        <label for="recibido_por_id" string="Recibido por"/>
                        <div class="o_row">
                            <field name="recibido_por_id" options="{'no_create': True}"/>
                            <label for="recibido_fecha" string="Fecha"/>
                            <field name="recibido_fecha"/>
                        </div>
                    </group>
                    <group string="Validación">
                        <label for="entregada_por_id" string="Entregada por"/>
                        <div class="o_row">
                            <field name="entregada_por_id" options="{'no_create': True}"/>
                            <label for="entregada_fecha" string="Fecha"/>
                            <field name="entregada_fecha"/>
                        </div>

                        <label for="contabilizada_por_id" string="Contabilizada por"/>
                        <div class="o_row">
                            <field name="contabilizada_por_id" options="{'no_create': True}"/>
                            <label for="contabilizada_fecha" string="Fecha"/>
                            <field name="contabilizada_fecha"/>
                        </div>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" string="Facturar" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_signature_selection_wizard" model="ir.actions.act_window">
        <field name="name">Facturar Servicio</field>
        <field name="res_model">signature.selection.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
