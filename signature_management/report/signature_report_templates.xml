<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action for Specific Contract -->
    <record id="action_report_contrato_especifico" model="ir.actions.report">
        <field name="name">Imprimir Contrato Específico</field>
        <field name="model">contrato.especifico</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">signature_management.report_contrato_especifico_template</field>
        <field name="report_file">signature_management.report_contrato_especifico_template</field>
        <field name="print_report_name">'Contrato Específico - %s' % (object.name)</field>
        <field name="binding_model_id" ref="contratos_especificos.model_contrato_especifico"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Reusable Signature Snippet -->
    <template id="report_signature_block">
        <div class="mt-5" style="page-break-inside: avoid;">
            <table class="table table-borderless" style="width: 100%;">
                <tr>
                    <td style="width: 50%; text-align: center; vertical-align: top; border: none;">
                        <div style="border-bottom: 1px solid black; min-height: 80px; margin-bottom: 10px;">
                            <t t-if="o.provider_signature_id.image">
                                <img t-att-src="image_data_uri(o.provider_signature_id.image)" style="max-height: 80px; max-width: 200px;"/>
                            </t>
                        </div>
                        <div style="font-weight: bold; text-transform: uppercase;">firma del prestador</div>
                        <div t-field="o.provider_signature_id.name" style="font-size: 11px;"/>
                    </td>
                    <td style="width: 50%; text-align: center; vertical-align: top; border: none;">
                        <div style="border-bottom: 1px solid black; min-height: 80px; margin-bottom: 10px;">
                            <t t-if="o.customer_signature_id.image">
                                <img t-att-src="image_data_uri(o.customer_signature_id.image)" style="max-height: 80px; max-width: 200px;"/>
                            </t>
                        </div>
                        <div style="font-weight: bold; text-transform: uppercase;">firma del cliente</div>
                        <div t-field="o.customer_signature_id.name" style="font-size: 11px;"/>
                    </td>
                </tr>
            </table>
        </div>
    </template>

    <!-- Specific Contract Template -->
    <template id="report_contrato_especifico_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="text-align: justify; font-size: 12px;">
                            <t t-out="o.content"/>
                        </div>

                        <!-- Service Lines Table -->
                        <div class="mt-4">
                            <h4 style="font-size: 14px; font-weight: bold; border-bottom: 1px solid black; padding-bottom: 5px;">Líneas de Servicios</h4>
                            <table class="table table-sm table-bordered" style="width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 10px;">
                                <thead style="background-color: #f2f2f2;">
                                    <tr>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Producto/Servicio</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Descripción</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Fecha Inicio</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Fecha Final</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Cant.</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">UdM</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Precio Unit.</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Importe</th>
                                        <th style="border: 1px solid black; padding: 4px; text-align: center;">Límite Fact.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.line_ids" t-as="line">
                                        <tr>
                                            <td style="border: 1px solid black; padding: 4px;"><span t-field="line.product_id.name"/></td>
                                            <td style="border: 1px solid black; padding: 4px;"><span t-field="line.name"/></td>
                                            <td style="border: 1px solid black; padding: 4px; text-align: center;"><span t-field="line.start_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/></td>
                                            <td style="border: 1px solid black; padding: 4px; text-align: center;"><span t-field="line.end_date" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/></td>
                                            <td style="border: 1px solid black; padding: 4px; text-align: right;"><span t-field="line.quantity"/></td>
                                            <td style="border: 1px solid black; padding: 4px; text-align: center;"><span t-field="line.uom_id.name"/></td>
                                            <td style="border: 1px solid black; padding: 4px; text-align: right;"><span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/></td>
                                            <td style="border: 1px solid black; padding: 4px; text-align: right;"><span t-field="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/></td>
                                            <td style="border: 1px solid black; padding: 4px; text-align: center;"><span t-field="line.date_deadline_invoice" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <!-- Signature Block -->
                        <t t-call="signature_management.report_signature_block"/>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- Inherit Master Contract Template to add signatures -->
    <template id="report_contrato_marco_signatures" inherit_id="contratos.report_contrato_marco_template">
        <xpath expr="//div[contains(@class, 'page')]" position="inside">
            <t t-call="signature_management.report_signature_block"/>
        </xpath>
    </template>
</odoo>
