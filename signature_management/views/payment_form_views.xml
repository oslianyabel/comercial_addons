<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_signature_payment_form_tree" model="ir.ui.view">
        <field name="name">signature.payment.form.tree</field>
        <field name="model">signature.payment.form</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_signature_payment_form_form" model="ir.ui.view">
        <field name="name">signature.payment.form.form</field>
        <field name="model">signature.payment.form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_signature_payment_form" model="ir.actions.act_window">
        <field name="name">Formas de pago</field>
        <field name="res_model">signature.payment.form</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_signature_payment_form"
        name="Formas de pago"
        action="action_signature_payment_form"
        parent="contacts.res_partner_menu_config"
        sequence="50"/>
</odoo>
